<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>English On The Go</title>
<link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@300;700;900&family=DM+Sans:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0a0a0f;
  --surface: #13131a;
  --card: #1a1a24;
  --border: #2a2a3a;
  --accent: #ff6b35;
  --accent2: #7c3aed;
  --gold: #f59e0b;
  --green: #10b981;
  --text: #f0f0f5;
  --muted: #8888aa;
  --font-head: 'Unbounded', sans-serif;
  --font-body: 'DM Sans', sans-serif;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: var(--bg); color: var(--text); font-family: var(--font-body); min-height: 100vh; overflow-x: hidden; }
body::before { content: ''; position: fixed; inset: 0; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E"); pointer-events: none; z-index: 0; }
.screen { display: none; padding: 24px 20px 100px; max-width: 480px; margin: 0 auto; position: relative; z-index: 1; }
.screen.active { display: block; }
nav { position: fixed; bottom: 0; left: 0; right: 0; background: rgba(13,13,20,0.95); backdrop-filter: blur(20px); border-top: 1px solid var(--border); display: flex; justify-content: space-around; padding: 12px 0 20px; z-index: 100; }
nav button { background: none; border: none; color: var(--muted); font-family: var(--font-body); font-size: 10px; font-weight: 400; display: flex; flex-direction: column; align-items: center; gap: 4px; cursor: pointer; padding: 4px 16px; transition: color 0.2s; }
nav button.active { color: var(--accent); }
nav button span.icon { font-size: 22px; }
.app-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28px; }
.logo { font-family: var(--font-head); font-size: 13px; font-weight: 900; letter-spacing: 0.05em; background: linear-gradient(135deg, var(--accent), var(--gold)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
.streak-badge { background: linear-gradient(135deg, #ff6b35, #ff9f1c); color: white; border-radius: 20px; padding: 5px 14px; font-size: 12px; font-weight: 700; font-family: var(--font-head); }
.level-card { background: linear-gradient(135deg, var(--accent2) 0%, #1a1a40 100%); border-radius: 20px; padding: 24px; margin-bottom: 20px; position: relative; overflow: hidden; }
.level-card::after { content: ''; position: absolute; right: -20px; top: -20px; width: 120px; height: 120px; background: radial-gradient(circle, rgba(255,255,255,0.1), transparent 70%); border-radius: 50%; }
.level-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.15em; opacity: 0.7; margin-bottom: 4px; }
.level-title { font-family: var(--font-head); font-size: 22px; font-weight: 900; }
.level-sub { font-size: 13px; opacity: 0.7; margin-top: 4px; }
.progress-bar { background: rgba(255,255,255,0.15); border-radius: 99px; height: 6px; margin-top: 16px; }
.progress-fill { background: linear-gradient(90deg, #fff, var(--gold)); border-radius: 99px; height: 100%; transition: width 0.5s ease; }
.section-title { font-family: var(--font-head); font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--muted); margin-bottom: 14px; }
.sessions-grid { display: flex; flex-direction: column; gap: 12px; margin-bottom: 28px; }
.session-card { background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 16px 18px; display: flex; align-items: center; gap: 14px; cursor: pointer; transition: all 0.2s; position: relative; overflow: hidden; }
.session-card:active { transform: scale(0.98); }
.session-card.locked { opacity: 0.4; cursor: not-allowed; }
.session-card::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; border-radius: 3px 0 0 3px; }
.session-card[data-type="vocab"]::before { background: var(--accent); }
.session-card[data-type="phrase"]::before { background: var(--accent2); }
.session-card[data-type="listen"]::before { background: var(--green); }
.session-card[data-type="repeat"]::before { background: var(--gold); }
.session-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0; }
.session-card[data-type="vocab"] .session-icon { background: rgba(255,107,53,0.15); }
.session-card[data-type="phrase"] .session-icon { background: rgba(124,58,237,0.15); }
.session-card[data-type="listen"] .session-icon { background: rgba(16,185,129,0.15); }
.session-card[data-type="repeat"] .session-icon { background: rgba(245,158,11,0.15); }
.session-info { flex: 1; }
.session-name { font-size: 15px; font-weight: 400; margin-bottom: 2px; }
.session-meta { font-size: 12px; color: var(--muted); }
.session-duration { font-family: var(--font-head); font-size: 11px; color: var(--muted); flex-shrink: 0; }
.done-check { color: var(--green); font-size: 18px; }
.player-back { background: none; border: none; color: var(--muted); font-size: 22px; cursor: pointer; margin-bottom: 24px; display: block; }
.player-type-tag { display: inline-block; padding: 4px 12px; border-radius: 99px; font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 12px; }
.tag-vocab { background: rgba(255,107,53,0.2); color: var(--accent); }
.tag-phrase { background: rgba(124,58,237,0.2); color: #a78bfa; }
.tag-listen { background: rgba(16,185,129,0.2); color: var(--green); }
.tag-repeat { background: rgba(245,158,11,0.2); color: var(--gold); }
.player-title { font-family: var(--font-head); font-size: 26px; font-weight: 900; line-height: 1.2; margin-bottom: 8px; }
.player-sub { color: var(--muted); font-size: 14px; margin-bottom: 32px; }
.visualizer { display: flex; align-items: center; justify-content: center; gap: 4px; height: 60px; margin-bottom: 24px; }
.bar { width: 4px; border-radius: 99px; background: linear-gradient(180deg, var(--accent), var(--accent2)); transition: height 0.15s ease; }
.lesson-card { background: var(--card); border: 1px solid var(--border); border-radius: 20px; padding: 24px; margin-bottom: 16px; }
.lesson-card.highlight { background: linear-gradient(135deg, rgba(255,107,53,0.1), rgba(124,58,237,0.1)); border-color: rgba(255,107,53,0.3); }
.word-en { font-family: var(--font-head); font-size: 28px; font-weight: 900; color: var(--accent); margin-bottom: 4px; }
.word-phonetic { color: var(--muted); font-size: 14px; font-style: italic; margin-bottom: 10px; }
.word-fr { font-size: 18px; font-weight: 300; margin-bottom: 14px; }
.word-example { font-size: 14px; color: var(--muted); border-left: 2px solid var(--border); padding-left: 12px; font-style: italic; }
.word-example em { color: var(--accent); font-style: normal; }
.audio-controls { display: flex; align-items: center; justify-content: center; gap: 24px; margin: 28px 0; }
.ctrl-btn { background: none; border: none; color: var(--text); cursor: pointer; font-size: 28px; padding: 4px; transition: transform 0.15s, color 0.15s; }
.ctrl-btn:active { transform: scale(0.9); }
.ctrl-btn.secondary { color: var(--muted); font-size: 22px; }
.play-btn { width: 68px; height: 68px; border-radius: 50%; background: linear-gradient(135deg, var(--accent), var(--accent2)); border: none; color: white; font-size: 28px; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 8px 30px rgba(255,107,53,0.4); transition: transform 0.15s, box-shadow 0.15s; }
.play-btn:active { transform: scale(0.95); box-shadow: 0 4px 15px rgba(255,107,53,0.3); }
.play-btn.playing { box-shadow: 0 0 0 8px rgba(255,107,53,0.2), 0 8px 30px rgba(255,107,53,0.4); }
.speed-selector { display: flex; gap: 8px; justify-content: center; margin-bottom: 20px; }
.speed-btn { background: var(--card); border: 1px solid var(--border); color: var(--muted); border-radius: 99px; padding: 6px 16px; font-size: 13px; cursor: pointer; font-family: var(--font-body); transition: all 0.2s; }
.speed-btn.active { background: var(--accent); border-color: var(--accent); color: white; }
.quiz-question { font-size: 18px; font-weight: 300; text-align: center; margin-bottom: 8px; line-height: 1.5; }
.quiz-en { font-family: var(--font-head); font-size: 32px; font-weight: 900; text-align: center; color: var(--accent); margin-bottom: 32px; }
.quiz-options { display: flex; flex-direction: column; gap: 10px; margin-bottom: 24px; }
.quiz-opt { background: var(--card); border: 1px solid var(--border); border-radius: 14px; padding: 16px 20px; font-size: 16px; cursor: pointer; transition: all 0.2s; text-align: left; font-family: var(--font-body); }
.quiz-opt.correct { background: rgba(16,185,129,0.15); border-color: var(--green); color: var(--green); }
.quiz-opt.wrong { background: rgba(239,68,68,0.1); border-color: #ef4444; color: #ef4444; }
.quiz-feedback { display: none; text-align: center; padding: 16px; border-radius: 14px; font-size: 15px; margin-bottom: 16px; }
.quiz-feedback.show { display: block; }
.quiz-feedback.good { background: rgba(16,185,129,0.1); color: var(--green); }
.quiz-feedback.bad { background: rgba(239,68,68,0.08); color: #ef4444; }
.stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 24px; }
.stat-card { background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 18px; }
.stat-num { font-family: var(--font-head); font-size: 32px; font-weight: 900; background: linear-gradient(135deg, var(--accent), var(--gold)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
.stat-label { font-size: 12px; color: var(--muted); margin-top: 4px; }
.tip-card { background: linear-gradient(135deg, rgba(124,58,237,0.15), rgba(255,107,53,0.05)); border: 1px solid rgba(124,58,237,0.3); border-radius: 16px; padding: 18px; margin-bottom: 12px; }
.tip-title { font-weight: 700; font-size: 14px; margin-bottom: 6px; }
.tip-text { font-size: 13px; color: var(--muted); line-height: 1.6; }
.big-phrase { background: linear-gradient(135deg, var(--card), var(--surface)); border: 1px solid var(--border); border-radius: 24px; padding: 32px 24px; text-align: center; margin-bottom: 20px; }
.phrase-en { font-family: var(--font-head); font-size: 22px; font-weight: 700; line-height: 1.4; margin-bottom: 16px; color: var(--text); }
.phrase-fr { font-size: 16px; color: var(--muted); font-weight: 300; }
.phrase-tip { font-size: 13px; color: var(--accent); margin-top: 12px; font-style: italic; }
.repeat-btn { width: 100%; padding: 18px; background: linear-gradient(135deg, var(--accent), var(--accent2)); border: none; color: white; border-radius: 16px; font-family: var(--font-head); font-size: 15px; font-weight: 700; cursor: pointer; letter-spacing: 0.05em; box-shadow: 0 8px 25px rgba(255,107,53,0.3); transition: all 0.2s; }
.repeat-btn:active { transform: scale(0.98); }
.next-btn { width: 100%; padding: 16px; background: var(--card); border: 1px solid var(--border); color: var(--text); border-radius: 16px; font-family: var(--font-head); font-size: 13px; font-weight: 700; cursor: pointer; letter-spacing: 0.05em; margin-top: 10px; transition: all 0.2s; }
.dots { display: flex; justify-content: center; gap: 6px; margin: 20px 0; }
.dot { width: 6px; height: 6px; border-radius: 50%; background: var(--border); transition: all 0.3s; }
.dot.active { background: var(--accent); width: 20px; border-radius: 3px; }
@keyframes wave { 0%,100% { height: 8px; } 50% { height: 32px; } }
@keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
.fade-up { animation: fadeUp 0.35s ease both; }
</style>
</head>
<body>

<div id="screen-home" class="screen active">
  <div class="app-header">
    <span class="logo">ENGLISH ON THE GO</span>
    <span class="streak-badge">🔥 3 jours</span>
  </div>
  <div class="level-card">
    <div class="level-label">Ton niveau actuel</div>
    <div class="level-title">Débutant+</div>
    <div class="level-sub">A2 → B1 en cours</div>
    <div class="progress-bar"><div class="progress-fill" style="width:28%"></div></div>
  </div>
  <div class="section-title">Session du jour · 15 min</div>
  <div class="sessions-grid">
    <div class="session-card" data-type="vocab" onclick="openSession('vocab')">
      <div class="session-icon">📦</div>
      <div class="session-info"><div class="session-name">Vocabulaire voyageur</div><div class="session-meta">15 mots · UK & USA</div></div>
      <div class="session-duration">5 min</div>
    </div>
    <div class="session-card" data-type="phrase" onclick="openSession('phrase')">
      <div class="session-icon">💬</div>
      <div class="session-info"><div class="session-name">Phrases du quotidien</div><div class="session-meta">Écoute + répète</div></div>
      <div class="session-duration">5 min</div>
    </div>
    <div class="session-card" data-type="listen" onclick="openSession('quiz')">
      <div class="session-icon">🧠</div>
      <div class="session-info"><div class="session-name">Mini quiz flash</div><div class="session-meta">Teste ta mémoire</div></div>
      <div class="session-duration">3 min</div>
    </div>
    <div class="session-card" data-type="repeat" onclick="openSession('repeat')">
      <div class="session-icon">🎙️</div>
      <div class="session-info"><div class="session-name">Shadowing express</div><div class="session-meta">Imite · mémorise</div></div>
      <div class="session-duration">5 min</div>
    </div>
  </div>
</div>

<div id="screen-vocab" class="screen">
  <button class="player-back" onclick="goHome()">←</button>
  <span class="player-type-tag tag-vocab">Vocabulaire</span>
  <div class="player-title">Voyageur UK & USA</div>
  <div class="player-sub">Transport, restos, shopping, orientation — le vrai quotidien</div>
  <div class="visualizer" id="viz">
    <div class="bar" style="height:12px"></div><div class="bar" style="height:20px"></div>
    <div class="bar" style="height:28px"></div><div class="bar" style="height:16px"></div>
    <div class="bar" style="height:36px"></div><div class="bar" style="height:24px"></div>
    <div class="bar" style="height:18px"></div><div class="bar" style="height:32px"></div>
    <div class="bar" style="height:14px"></div><div class="bar" style="height:22px"></div>
  </div>
  <div class="speed-selector">
    <button class="speed-btn" onclick="setSpeed(0.7,this)">🐢 Lent</button>
    <button class="speed-btn active" onclick="setSpeed(1,this)">Normal</button>
    <button class="speed-btn" onclick="setSpeed(1.3,this)">⚡ Vite</button>
  </div>
  <div id="vocab-card" class="lesson-card highlight fade-up"></div>
  <div class="audio-controls">
    <button class="ctrl-btn secondary" onclick="prevVocab()">⏮</button>
    <button class="play-btn" id="playBtn" onclick="togglePlay()">▶</button>
    <button class="ctrl-btn secondary" onclick="nextVocab()">⏭</button>
  </div>
  <div class="dots" id="vocab-dots"></div>
  <button class="repeat-btn" onclick="speakCurrent()">🔊 Réécouter ce mot</button>
</div>

<div id="screen-phrase" class="screen">
  <button class="player-back" onclick="goHome()">←</button>
  <span class="player-type-tag tag-phrase">Phrases clés</span>
  <div class="player-title">Parle comme un natif</div>
  <div class="player-sub">Pas besoin de regarder — écoute et répète</div>
  <div id="phrase-card" class="big-phrase fade-up"></div>
  <div class="dots" id="phrase-dots"></div>
  <button class="repeat-btn" onclick="speakPhrase()">🔊 Écouter la phrase</button>
  <button class="next-btn" onclick="nextPhrase()">→ Phrase suivante</button>
</div>

<div id="screen-quiz" class="screen">
  <button class="player-back" onclick="goHome()">←</button>
  <span class="player-type-tag tag-listen">Quiz flash</span>
  <div class="player-title">Teste ta mémoire</div>
  <div class="player-sub" id="quiz-progress-text">Question 1 / 7</div>
  <div class="dots" id="quiz-dots"></div>
  <br>
  <div class="quiz-question">Comment dit-on en anglais ?</div>
  <div class="quiz-en" id="quiz-word"></div>
  <div class="quiz-options" id="quiz-opts"></div>
  <div class="quiz-feedback" id="quiz-fb"></div>
</div>

<div id="screen-repeat" class="screen">
  <button class="player-back" onclick="goHome()">←</button>
  <span class="player-type-tag tag-repeat">Shadowing</span>
  <div class="player-title">Imite, répète, retiens</div>
  <div class="player-sub">Méthode des acteurs — ton cerveau mémorise en mimant</div>
  <div id="shadow-card" class="big-phrase fade-up"></div>
  <div class="dots" id="shadow-dots"></div>
  <button class="repeat-btn" onclick="speakShadow()">🎙️ Écouter & imiter</button>
  <button class="next-btn" onclick="nextShadow()">✓ C'est bon, suivant</button>
</div>

<div id="screen-stats" class="screen">
  <div class="app-header"><span class="logo">MES PROGRÈS</span></div>
  <div class="stats-grid">
    <div class="stat-card"><div class="stat-num">47</div><div class="stat-label">Mots appris</div></div>
    <div class="stat-card"><div class="stat-num">3</div><div class="stat-label">Jours de suite 🔥</div></div>
    <div class="stat-card"><div class="stat-num">2.1h</div><div class="stat-label">Temps total</div></div>
    <div class="stat-card"><div class="stat-num">78%</div><div class="stat-label">Score quiz</div></div>
  </div>
  <div class="section-title">Rappels à réviser</div>
  <div class="sessions-grid" id="review-list"></div>
  <div class="section-title" style="margin-top:8px">Conseils pour toi</div>
  <div class="tip-card"><div class="tip-title">🔁 La répétition espacée</div><div class="tip-text">Ton cerveau retient mieux si tu révises un mot à J+1, J+3, J+7. Cette app le fait automatiquement — ne saute pas les rappels.</div></div>
  <div class="tip-card"><div class="tip-title">🎧 Écoute passive</div><div class="tip-text">Même en travaillant, l'oreille absorbe. Après 10 écoutes d'un mot, il passe en mémoire long terme — sans effort conscient.</div></div>
  <div class="tip-card"><div class="tip-title">🗣️ Parle à voix basse</div><div class="tip-text">Même murmurer active la mémoire musculaire. Tu mémorises 3× plus vite que juste en lisant.</div></div>
</div>

<nav>
  <button class="active" id="nav-home" onclick="showTab('home')"><span class="icon">🏠</span>Accueil</button>
  <button id="nav-play" onclick="showTab('vocab')"><span class="icon">▶️</span>Écouter</button>
  <button id="nav-stats" onclick="showTab('stats')"><span class="icon">📊</span>Progrès</button>
</nav>

<script>
const vocabList = [
  { en: "check in", phonetic: "/tʃek ɪn/", fr: "s'enregistrer (hôtel/aéroport)", ex: "I need to <em>check in</em> before 3 PM." },
  { en: "carry-on", phonetic: "/ˈkæri ɒn/", fr: "bagage cabine", ex: "Your <em>carry-on</em> must fit in the overhead bin." },
  { en: "layover", phonetic: "/ˈleɪəʊvər/", fr: "escale", ex: "We have a 2-hour <em>layover</em> in London." },
  { en: "fare", phonetic: "/feər/", fr: "le tarif (transport)", ex: "What's the <em>fare</em> to the city centre?" },
  { en: "tip", phonetic: "/tɪp/", fr: "le pourboire", ex: "A 15% <em>tip</em> is expected in the US." },
  { en: "receipt", phonetic: "/rɪˈsiːt/", fr: "le reçu", ex: "Can I have a <em>receipt</em>, please?" },
  { en: "roundabout", phonetic: "/ˈraʊndəbaʊt/", fr: "le rond-point (UK)", ex: "Take the second exit at the <em>roundabout</em>." },
  { en: "restroom", phonetic: "/ˈrestruːm/", fr: "les toilettes (US)", ex: "Where is the <em>restroom</em>, please?" },
  { en: "sightseeing", phonetic: "/ˈsaɪtsiːɪŋ/", fr: "visiter des sites", ex: "We spent the day <em>sightseeing</em> in Edinburgh." },
  { en: "landmark", phonetic: "/ˈlændmɑːk/", fr: "le monument / le repère", ex: "Big Ben is the most famous <em>landmark</em> in London." },
  { en: "currency exchange", phonetic: "/ˈkʌrənsi ɪksˈtʃeɪndʒ/", fr: "le bureau de change", ex: "Is there a <em>currency exchange</em> nearby?" },
  { en: "rush hour", phonetic: "/rʌʃ aʊər/", fr: "les heures de pointe", ex: "Avoid the tube during <em>rush hour</em>." },
  { en: "one-way", phonetic: "/wʌn weɪ/", fr: "aller simple", ex: "A <em>one-way</em> ticket to Manchester, please." },
  { en: "outlet", phonetic: "/ˈaʊtlɛt/", fr: "la prise électrique (US)", ex: "Do you have an <em>outlet</em> I can use?" },
  { en: "neighborhood", phonetic: "/ˈneɪbəhʊd/", fr: "le quartier (US)", ex: "This is a really lively <em>neighborhood</em>." },
];

const phrases = [
  { en: "Could you recommend a good restaurant nearby?", fr: "Pouvez-vous recommander un bon restaurant près d'ici ?", tip: "La phrase touristique n°1" },
  { en: "How do I get to the city centre from here?", fr: "Comment rejoindre le centre-ville depuis ici ?", tip: "Dans la rue ou à l'hôtel" },
  { en: "I'd like a table for two, please.", fr: "Je voudrais une table pour deux, s'il vous plaît.", tip: "Au restaurant — simple et efficace" },
  { en: "Is the tip included in the bill?", fr: "Le pourboire est-il inclus dans l'addition ?", tip: "Crucial aux USA !" },
  { en: "Can I pay by card?", fr: "Est-ce que je peux payer par carte ?", tip: "Toujours utile" },
  { en: "Where is the nearest underground station?", fr: "Où est la station de métro la plus proche ?", tip: "UK — le tube à Londres" },
  { en: "I think I'm lost. Can you help me?", fr: "Je crois que je suis perdu. Pouvez-vous m'aider ?", tip: "Honnête et direct" },
  { en: "What time does it close?", fr: "À quelle heure ça ferme ?", tip: "Musée, shop, bar…" },
  { en: "Do you have anything smaller? I only have a fifty.", fr: "Vous avez de la monnaie ? Je n'ai qu'un billet de 50.", tip: "Très fréquent" },
  { en: "That was absolutely delicious, thank you!", fr: "C'était absolument délicieux, merci !", tip: "Les locaux adorent ça" },
];

const shadowPhrases = [
  { en: "Excuse me, is this seat taken?", fr: "Excusez-moi, cette place est-elle prise ?", tip: "Dans le bus, le pub, le train…" },
  { en: "I'll have what they're having, please.", fr: "Je prendrai la même chose qu'eux, s'il vous plaît.", tip: "Au bar — fait toujours son effet" },
  { en: "Sorry, could you speak a little more slowly?", fr: "Désolé, pouvez-vous parler un peu plus lentement ?", tip: "Ne jamais hésiter à demander ça" },
  { en: "What would you recommend from the menu?", fr: "Que recommandez-vous sur la carte ?", tip: "Engage la conversation et tu manges bien" },
  { en: "We're just browsing, thanks.", fr: "On regarde juste, merci.", tip: "Dans les shops — évite les vendeurs insistants" },
  { en: "Could we get the bill, please?", fr: "L'addition, s'il vous plaît.", tip: "UK — toujours poli avec 'could we'" },
  { en: "This is my first time in London — any tips?", fr: "C'est ma première fois à Londres — des conseils ?", tip: "Brise-glace universel avec les locaux" },
];

const quizData = [
  { fr: "le pourboire", en: "tip", opts: ["tip", "fare", "receipt", "layover"] },
  { fr: "le reçu", en: "receipt", opts: ["receipt", "fare", "tip", "carry-on"] },
  { fr: "les heures de pointe", en: "rush hour", opts: ["rush hour", "layover", "one-way", "landmark"] },
  { fr: "le monument", en: "landmark", opts: ["landmark", "neighborhood", "roundabout", "outlet"] },
  { fr: "escale", en: "layover", opts: ["layover", "check in", "one-way", "fare"] },
  { fr: "bagage cabine", en: "carry-on", opts: ["carry-on", "checkout", "receipt", "landmark"] },
  { fr: "le quartier (US)", en: "neighborhood", opts: ["neighborhood", "roundabout", "rush hour", "outlet"] },
];

let vocabIdx = 0, phraseIdx = 0, shadowIdx = 0, quizIdx = 0;
let isPlaying = false, autoTimer = null, speechRate = 1;

function showTab(tab) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('nav button').forEach(b => b.classList.remove('active'));
  if (tab === 'home') { document.getElementById('screen-home').classList.add('active'); document.getElementById('nav-home').classList.add('active'); }
  else if (tab === 'vocab') { document.getElementById('screen-vocab').classList.add('active'); document.getElementById('nav-play').classList.add('active'); renderVocab(); }
  else if (tab === 'stats') { document.getElementById('screen-stats').classList.add('active'); document.getElementById('nav-stats').classList.add('active'); renderReviews(); }
}

function openSession(type) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('nav button').forEach(b => b.classList.remove('active'));
  if (type === 'vocab') { document.getElementById('screen-vocab').classList.add('active'); renderVocab(); }
  if (type === 'phrase') { document.getElementById('screen-phrase').classList.add('active'); renderPhrase(); }
  if (type === 'quiz') { document.getElementById('screen-quiz').classList.add('active'); renderQuiz(); }
  if (type === 'repeat') { document.getElementById('screen-repeat').classList.add('active'); renderShadow(); }
}

function goHome() {
  stopAuto();
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screen-home').classList.add('active');
  document.getElementById('nav-home').classList.add('active');
}

function renderVocab() {
  const v = vocabList[vocabIdx];
  document.getElementById('vocab-card').innerHTML = `<div class="word-en">${v.en}</div><div class="word-phonetic">${v.phonetic}</div><div class="word-fr">${v.fr}</div><div class="word-example">${v.ex}</div>`;
  renderDots('vocab-dots', vocabList.length, vocabIdx);
}

function renderDots(id, total, active) {
  document.getElementById(id).innerHTML = Array.from({length: total}, (_, i) => `<div class="dot ${i === active ? 'active' : ''}"></div>`).join('');
}

function nextVocab() { vocabIdx = (vocabIdx + 1) % vocabList.length; renderVocab(); speakCurrent(); }
function prevVocab() { vocabIdx = (vocabIdx - 1 + vocabList.length) % vocabList.length; renderVocab(); speakCurrent(); }

function speakCurrent() {
  speak(vocabList[vocabIdx].en);
  animateViz(true);
  setTimeout(() => animateViz(false), 1200);
}

function togglePlay() {
  isPlaying = !isPlaying;
  const btn = document.getElementById('playBtn');
  btn.textContent = isPlaying ? '⏸' : '▶';
  btn.classList.toggle('playing', isPlaying);
  if (isPlaying) startAuto(); else stopAuto();
}

function startAuto() { speakCurrent(); autoTimer = setInterval(() => { nextVocab(); }, 4000); }
function stopAuto() {
  isPlaying = false;
  const btn = document.getElementById('playBtn');
  if (btn) { btn.textContent = '▶'; btn.classList.remove('playing'); }
  clearInterval(autoTimer);
}

function setSpeed(rate, el) {
  speechRate = rate;
  document.querySelectorAll('.speed-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
}

function renderPhrase() {
  const p = phrases[phraseIdx];
  document.getElementById('phrase-card').innerHTML = `<div class="phrase-en">${p.en}</div><div class="phrase-fr">${p.fr}</div><div class="phrase-tip">💡 ${p.tip}</div>`;
  renderDots('phrase-dots', phrases.length, phraseIdx);
}
function speakPhrase() { speak(phrases[phraseIdx].en); }
function nextPhrase() { phraseIdx = (phraseIdx + 1) % phrases.length; renderPhrase(); setTimeout(() => speakPhrase(), 300); }

function renderQuiz() {
  const q = quizData[quizIdx];
  document.getElementById('quiz-word').textContent = q.fr;
  document.getElementById('quiz-progress-text').textContent = `Question ${quizIdx+1} / ${quizData.length}`;
  renderDots('quiz-dots', quizData.length, quizIdx);
  const opts = [...q.opts].sort(() => Math.random() - 0.5);
  document.getElementById('quiz-opts').innerHTML = opts.map(o => `<button class="quiz-opt" onclick="checkAnswer('${o}','${q.en}',this)">${o}</button>`).join('');
  document.getElementById('quiz-fb').className = 'quiz-feedback';
  document.getElementById('quiz-fb').textContent = '';
}

function checkAnswer(chosen, correct, el) {
  document.querySelectorAll('.quiz-opt').forEach(b => b.onclick = null);
  const fb = document.getElementById('quiz-fb');
  if (chosen === correct) {
    el.classList.add('correct');
    fb.textContent = '✓ Parfait ! ' + correct + ' = ' + quizData[quizIdx].fr;
    fb.className = 'quiz-feedback show good';
  } else {
    el.classList.add('wrong');
    document.querySelectorAll('.quiz-opt').forEach(b => { if(b.textContent===correct) b.classList.add('correct'); });
    fb.textContent = '✗ La bonne réponse était : ' + correct;
    fb.className = 'quiz-feedback show bad';
  }
  speak(correct);
  setTimeout(() => { quizIdx = (quizIdx + 1) % quizData.length; renderQuiz(); }, 2200);
}

function renderShadow() {
  const s = shadowPhrases[shadowIdx];
  document.getElementById('shadow-card').innerHTML = `<div class="phrase-en">${s.en}</div><div class="phrase-fr">${s.fr}</div><div class="phrase-tip">🎯 ${s.tip}</div>`;
  renderDots('shadow-dots', shadowPhrases.length, shadowIdx);
}
function speakShadow() { speak(shadowPhrases[shadowIdx].en, 0.85); }
function nextShadow() { shadowIdx = (shadowIdx + 1) % shadowPhrases.length; renderShadow(); }

function renderReviews() {
  document.getElementById('review-list').innerHTML = vocabList.slice(0,3).map(v => `<div class="session-card" data-type="repeat" onclick="openSession('vocab')"><div class="session-icon">🔁</div><div class="session-info"><div class="session-name">${v.en}</div><div class="session-meta">${v.fr} · À réviser</div></div></div>`).join('');
}

function speak(text, rate) {
  if (!window.speechSynthesis) return;
  window.speechSynthesis.cancel();
  const u = new SpeechSynthesisUtterance(text);
  u.lang = 'en-US';
  u.rate = rate || speechRate;
  u.pitch = 1;
  const voices = window.speechSynthesis.getVoices();
  const en = voices.find(v => v.lang.startsWith('en') && v.name.includes('Google')) || voices.find(v => v.lang.startsWith('en'));
  if (en) u.voice = en;
  window.speechSynthesis.speak(u);
}

function animateViz(on) {
  document.querySelectorAll('.bar').forEach(b => {
    if (on) { b.style.animation = `wave ${0.4 + Math.random()*0.4}s ease-in-out infinite`; b.style.animationDelay = Math.random()*0.3+'s'; }
    else { b.style.animation = 'none'; b.style.height = (8 + Math.random()*20)+'px'; }
  });
}

window.speechSynthesis && window.speechSynthesis.addEventListener('voiceschanged', () => {});
renderVocab();
renderPhrase();
renderShadow();
</script>
</body>
</html>
