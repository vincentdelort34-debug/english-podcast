<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>English On The Go</title>
<link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@300;700;900&family=DM+Sans:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet">
<style>
:root{--bg:#0a0a0f;--surface:#13131a;--card:#1a1a24;--border:#2a2a3a;--accent:#ff6b35;--accent2:#7c3aed;--gold:#f59e0b;--green:#10b981;--text:#f0f0f5;--muted:#8888aa;--font-head:'Unbounded',sans-serif;--font-body:'DM Sans',sans-serif}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:var(--font-body);min-height:100vh;overflow-x:hidden}
.screen{display:none;padding:24px 20px 100px;max-width:480px;margin:0 auto;position:relative;z-index:1}
.screen.active{display:block}
nav{position:fixed;bottom:0;left:0;right:0;background:rgba(13,13,20,0.95);backdrop-filter:blur(20px);border-top:1px solid var(--border);display:flex;justify-content:space-around;padding:12px 0 20px;z-index:100}
nav button{background:none;border:none;color:var(--muted);font-family:var(--font-body);font-size:10px;display:flex;flex-direction:column;align-items:center;gap:4px;cursor:pointer;padding:4px 16px;transition:color 0.2s}
nav button.active{color:var(--accent)}
nav button span.icon{font-size:22px}
.app-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:28px}
.logo{font-family:var(--font-head);font-size:13px;font-weight:900;letter-spacing:0.05em;background:linear-gradient(135deg,var(--accent),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.streak-badge{background:linear-gradient(135deg,#ff6b35,#ff9f1c);color:white;border-radius:20px;padding:5px 14px;font-size:12px;font-weight:700;font-family:var(--font-head)}
.level-card{background:linear-gradient(135deg,var(--accent2) 0%,#1a1a40 100%);border-radius:20px;padding:24px;margin-bottom:20px;position:relative;overflow:hidden}
.level-label{font-size:11px;text-transform:uppercase;letter-spacing:0.15em;opacity:0.7;margin-bottom:4px}
.level-title{font-family:var(--font-head);font-size:22px;font-weight:900}
.level-sub{font-size:13px;opacity:0.7;margin-top:4px}
.progress-bar{background:rgba(255,255,255,0.15);border-radius:99px;height:6px;margin-top:16px}
.progress-fill{background:linear-gradient(90deg,#fff,var(--gold));border-radius:99px;height:100%}
.section-title{font-family:var(--font-head);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);margin-bottom:14px}
.sessions-grid{display:flex;flex-direction:column;gap:12px;margin-bottom:28px}
.session-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:16px 18px;display:flex;align-items:center;gap:14px;cursor:pointer;transition:all 0.2s;position:relative;overflow:hidden}
.session-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;border-radius:3px 0 0 3px}
.session-card[data-type="vocab"]::before{background:var(--accent)}
.session-card[data-type="phrase"]::before{background:var(--accent2)}
.session-card[data-type="listen"]::before{background:var(--green)}
.session-card[data-type="repeat"]::before{background:var(--gold)}
.session-icon{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0}
.session-card[data-type="vocab"] .session-icon{background:rgba(255,107,53,0.15)}
.session-card[data-type="phrase"] .session-icon{background:rgba(124,58,237,0.15)}
.session-card[data-type="listen"] .session-icon{background:rgba(16,185,129,0.15)}
.session-card[data-type="repeat"] .session-icon{background:rgba(245,158,11,0.15)}
.session-info{flex:1}
.session-name{font-size:15px;font-weight:400;margin-bottom:2px}
.session-meta{font-size:12px;color:var(--muted)}
.session-duration{font-family:var(--font-head);font-size:11px;color:var(--muted);flex-shrink:0}
.done-check{color:var(--green);font-size:18px}
.player-back{background:none;border:none;color:var(--muted);font-size:22px;cursor:pointer;margin-bottom:24px;display:block}
.player-type-tag{display:inline-block;padding:4px 12px;border-radius:99px;font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:12px}
.tag-vocab{background:rgba(255,107,53,0.2);color:var(--accent)}
.tag-phrase{background:rgba(124,58,237,0.2);color:#a78bfa}
.tag-listen{background:rgba(16,185,129,0.2);color:var(--green)}
.tag-repeat{background:rgba(245,158,11,0.2);color:var(--gold)}
.player-title{font-family:var(--font-head);
